{
  "name": "frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test:unit": "vitest run --coverage=false --maxWorkers=1",
    "test:a11y": "vitest run src/a11y",
    "test:e2e": "node ./scripts/e2e-db-preflight.mjs && playwright test",
    "test:e2e:headed": "node ./scripts/e2e-db-preflight.mjs && playwright test --headed",
    "test:e2e:local": "node ./scripts/e2e-db-preflight.mjs && playwright test",
    "test:all": "npm run test:unit && npm run test:e2e",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@supabase/supabase-js": "^2.45.4",
    "@tanstack/react-query": "^5.90.21",
    "animejs": "^4.3.6",
    "motion": "^12.34.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "axe-core": "^4.11.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "pg": "^8.19.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.48.0",
    "vite": "^5.4.6",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0"
  }
}
