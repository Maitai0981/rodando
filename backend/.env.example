# Rodando — Backend environment template
# Copy this file to .env.local and fill in the values.
# .env.local is loaded automatically by Spring Boot on startup.
# Never commit .env.local or any file with real credentials.

# ─── Application ─────────────────────────────────────────────────────────────
# Environments: local | test | e2e | staging | production
APP_ENV=local

# HTTP port (default: 4000)
PORT=4000

# ─── Database ─────────────────────────────────────────────────────────────────
# SPRING_DATASOURCE_* takes precedence over DATABASE_URL when both are set.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/rodando
SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5432/rodando
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=

# ─── Flyway ───────────────────────────────────────────────────────────────────
FLYWAY_BASELINE_ON_MIGRATE=false
FLYWAY_BASELINE_VERSION=0

# ─── Seeding (dev/CI only) ────────────────────────────────────────────────────
# DB_RESET=1 drops and recreates the schema on startup (never in production)
DB_RESET=0
SEED_BASE_CATALOG=0
SEED_DEMO_DATA=0

# Owner account created automatically on first boot
OWNER_SEED_EMAIL=owner@rodando.local
OWNER_SEED_PASSWORD=
OWNER_SEED_NAME=Owner

# ─── Frontend / CORS ──────────────────────────────────────────────────────────
# Public URL of the frontend — used in Mercado Pago back_urls
# Must be HTTPS in production. localhost is also accepted (dev).
PUBLIC_APP_BASE_URL=http://localhost:5173

# Comma-separated list of CORS-allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Session Cookies ──────────────────────────────────────────────────────────
# Leave COOKIE_DOMAIN blank for localhost development
COOKIE_DOMAIN=
# Defaults to true when APP_ENV=production|staging
COOKIE_SECURE=

# ─── Payments ─────────────────────────────────────────────────────────────────
# Set to 1 to simulate all payments without calling external APIs.
# Automatically true when APP_ENV=test or APP_ENV=e2e.
MOCK_PAYMENT_PROVIDERS=0

PAYMENT_CARD_PROVIDER=mercado_pago
PAYMENT_PIX_PROVIDER=mercado_pago

# Mercado Pago credentials
# Use TEST-... prefix for sandbox; APP_USR-... for production.
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# Webhook notification URL — must be HTTPS for Mercado Pago to call it.
# In development use a tunnel like: ngrok http 4000
MERCADOPAGO_NOTIFICATION_URL=

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# When SMTP_HOST is blank, emails are logged (no real sending).
# Works with any SMTP provider: Gmail, SendGrid, Resend, Brevo, etc.
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USERNAME=your@gmail.com
#   SMTP_PASSWORD=<app-password>        # use an App Password, not your login password
#
# Resend / SendGrid: use smtp.resend.com or smtp.sendgrid.net and your API key
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=true
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=Rodando Moto Center

# ─── Alerts ───────────────────────────────────────────────────────────────────
ALERT_EMAIL_WEBHOOK_URL=
ALERT_WHATSAPP_WEBHOOK_URL=

# ─── Rate Limiting (optional overrides) ───────────────────────────────────────
# RATE_LIMIT_ENABLED=1
# AUTH_RATE_LIMIT_MAX=10
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# CHECKOUT_RATE_LIMIT_MAX=12
# CHECKOUT_RATE_LIMIT_WINDOW_MS=600000

# ─── Uploads ──────────────────────────────────────────────────────────────────
# Max image upload size in bytes (default: 6291456 = 6MB)
# UPLOAD_MAX_BYTES=6291456

# ─── E2E Testing ─────────────────────────────────────────────────────────────
# Allow the /api/e2e/reset endpoint (never enable in production)
E2E_ALLOW_RESET=0
E2E_RESET_TOKEN=
