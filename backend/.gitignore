# ── Build Maven ───────────────────────────────────────────────
target/
*.jar
*.war
*.class
HELP.md

# ── Maven wrapper — só o binário ──────────────────────────────
# mvnw e mvnw.cmd são rastreados intencionalmente
.mvn/wrapper/maven-wrapper.jar

# ── Variáveis de ambiente ─────────────────────────────────────
.env
.env.local
.env.*.local
# .env.example é rastreado — é um template sem segredos

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ── Performance (gerado por CI) ───────────────────────────────
perf/

# ── Uploads locais (preservar placeholder) ────────────────────
uploads/*
!uploads/.gitkeep

# ── Editores ──────────────────────────────────────────────────
.idea/
!.idea/.gitignore
*.iml
*.iws
.project
.classpath
.settings/
.vscode/
.DS_Store
Thumbs.db
