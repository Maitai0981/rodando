# Configuração local do docker-compose
# Copie este arquivo para .env e ajuste os valores.
# .env é lido automaticamente pelo docker-compose.

# ─── Banco de dados ───────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rodando

# ─── Backend ─────────────────────────────────────────────────────────────────
OWNER_SEED_EMAIL=owner@rodando.local
OWNER_SEED_PASSWORD=owner123
OWNER_SEED_NAME=Owner

# Semear produtos e ofertas de exemplo na primeira inicialização (1 = sim)
SEED_BASE_CATALOG=1
SEED_DEMO_DATA=1

# Simular pagamentos sem chamar API externa (1 = sim — recomendado local sem credenciais)
MOCK_PAYMENT_PROVIDERS=1

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
# Use prefixo TEST- para sandbox, APP_USR- para produção.
# Deixe em branco e MOCK_PAYMENT_PROVIDERS=1 para testar sem conta MP.
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_ACCESS_TOKEN=
# Segredo recebido no header X-Signature dos webhooks (configure no painel MP)
MERCADOPAGO_WEBHOOK_SECRET=
# URL pública do backend para receber notificações do MP (deve ser HTTPS)
# Em desenvolvimento use um túnel: ngrok http 4000
MERCADOPAGO_NOTIFICATION_URL=

# ─── E-mail — deixe em branco para apenas logar (não envia de verdade) ────────
SMTP_HOST=
SMTP_USERNAME=
SMTP_PASSWORD=

# ─── Frontend ─────────────────────────────────────────────────────────────────
# URL que o BROWSER usará para chamar o backend (não o nome do container)
VITE_API_URL=http://localhost:4000
