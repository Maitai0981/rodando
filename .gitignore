# ══════════════════════════════════════════════════════════════
# SISTEMA OPERACIONAL
# ══════════════════════════════════════════════════════════════
.DS_Store
Thumbs.db
desktop.ini

# ══════════════════════════════════════════════════════════════
# VARIÁVEIS DE AMBIENTE  (nunca rastrear valores reais)
# ══════════════════════════════════════════════════════════════
.env
.env.local
.env.*.local
.env.e2e
.env.e2e.local
.env.test
.env.test.local
.env.production
.env.production.local
# *.example e *.docker.example são rastreados — são templates sem segredos

# ══════════════════════════════════════════════════════════════
# LOGS
# ══════════════════════════════════════════════════════════════
*.log
logs/
output/

# ══════════════════════════════════════════════════════════════
# FRONTEND — Node / Vite / React / TypeScript
# ══════════════════════════════════════════════════════════════

# Dependências
node_modules/

# Build
dist/
dist-ssr/
frontend/dist/
frontend/.vite/

# Testes e cobertura
coverage/
frontend/coverage/
frontend/test-results/
frontend/playwright-report/
frontend/blob-report/
test-results/
playwright-report/
blob-report/

# TypeScript incremental
*.tsbuildinfo

# Vite
vite.config.ts.timestamp-*

# ══════════════════════════════════════════════════════════════
# BACKEND — Java / Spring Boot / Maven
# ══════════════════════════════════════════════════════════════

# Build Maven
backend/target/
backend/*.jar
backend/*.war
backend/*.class
backend/HELP.md

# Maven wrapper — só o binário; os scripts mvnw/mvnw.cmd são rastreados
backend/.mvn/wrapper/maven-wrapper.jar

# Variáveis de ambiente do backend
backend/.env
backend/.env.local
backend/.env.*.local

# Logs e perf
backend/*.log
backend/perf/

# Uploads locais — preservar placeholder
backend/uploads/*
!backend/uploads/.gitkeep

# ══════════════════════════════════════════════════════════════
# CLAUDE CODE
# ══════════════════════════════════════════════════════════════
.claude/
CLAUDE.md

# MCP com tokens locais
.mcp.json

# ══════════════════════════════════════════════════════════════
# EDITORES E IDEs
# ══════════════════════════════════════════════════════════════

# VS Code — manter extensões e configurações do projeto rastreadas
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# IntelliJ IDEA — regras finas ficam em backend/.idea/.gitignore
.idea/
!.idea/.gitignore
*.iml
*.iws

# Eclipse
.project
.classpath
.settings/

# Outros editores
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
