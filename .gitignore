# ── Claude Code ───────────────────────────────────────────────
# .claude/ contém configurações locais (não rastrear)
.claude/
# CLAUDE.md é rastreado intencionalmente (instruções do projeto)

# MCP servers locais (contêm tokens sensíveis)
.mcp.json

# ── Sistema operacional ───────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs (raiz) ───────────────────────────────────────────────
*.log
logs/
output/

# ══════════════════════════════════════════════════════════════
# FRONTEND (Node / Vite / React)
# ══════════════════════════════════════════════════════════════

node_modules/

# Build
dist/
dist-ssr/
frontend/dist/
frontend/.vite/

# Variáveis de ambiente — apenas arquivos com valores reais
.env
.env.local
.env.*.local
.env.e2e
.env.e2e.local
.env.test
.env.test.local
.env.production
.env.production.local
# .env.example e .env.docker.example são rastreados (são templates)

# Testes & cobertura
coverage/
frontend/coverage/
frontend/test-results/
frontend/playwright-report/
frontend/blob-report/
test-results/
playwright-report/

# TypeScript incremental
*.tsbuildinfo

# ══════════════════════════════════════════════════════════════
# BACKEND (Java / Spring Boot / Maven)
# ══════════════════════════════════════════════════════════════

# Maven build output
backend/target/
backend/build/
backend/*.jar
backend/*.war
backend/*.class
backend/HELP.md

# Maven wrapper binário (scripts mvnw/mvnw.cmd são rastreados)
backend/.mvn/wrapper/maven-wrapper.jar

# Gradle
backend/.gradle/

# Logs e perf
backend/*.log
backend/perf/

# Variáveis de ambiente do backend (contêm credenciais reais)
backend/.env
backend/.env.local
backend/.env.*.local

# Banco de dados local (SQLite legado)
backend/data/**/*.sqlite
backend/data/**/*.sqlite-*

# Uploads (preservar .gitkeep)
backend/uploads/*
!backend/uploads/.gitkeep

# Legado
backend/legacy/trash/

# ══════════════════════════════════════════════════════════════
# EDITORES & IDEs
# ══════════════════════════════════════════════════════════════

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# IntelliJ IDEA (regras finas ficam em backend/.idea/.gitignore)
.idea/
!.idea/.gitignore
*.iml
*.iws

# Outros
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.local
