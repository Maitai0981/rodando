# ══════════════════════════════════════════════════════════════
# FRONTEND (Node / Vite / React)
# ══════════════════════════════════════════════════════════════

node_modules/

# Build
dist/
dist-ssr/
frontend/dist/
frontend/.vite/

# Variáveis de ambiente
.env
.env.local
.env.*.local
.env.e2e
# .env.example é rastreado intencionalmente

# Testes & cobertura
coverage/
frontend/coverage/
frontend/test-results/
frontend/playwright-report/
frontend/blob-report/
test-results/
playwright-report/

# TypeScript incremental
*.tsbuildinfo

# ══════════════════════════════════════════════════════════════
# BACKEND (Java / Spring Boot / Maven)
# ══════════════════════════════════════════════════════════════

# Maven build output
backend/target/
backend/build/
backend/*.jar
backend/*.war
backend/*.class
backend/HELP.md

# Maven wrapper binário (scripts mvnw/mvnw.cmd são rastreados)
backend/.mvn/wrapper/maven-wrapper.jar

# Gradle
backend/.gradle/

# Logs e perf
backend/*.log
backend/perf/

# Banco de dados local (SQLite legado)
backend/data/**/*.sqlite
backend/data/**/*.sqlite-*

# Uploads (preservar .gitkeep)
backend/uploads/*
!backend/uploads/.gitkeep

# Legado
backend/legacy/trash/

# ══════════════════════════════════════════════════════════════
# EDITORES & IDEs
# ══════════════════════════════════════════════════════════════

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# IntelliJ IDEA (regras finas ficam em backend/.idea/.gitignore)
.idea/
!.idea/.gitignore
*.iml
*.iws

# Outros
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.local
